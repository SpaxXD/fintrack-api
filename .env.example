# ==============================================================================
# FinTrack API - Configuração de Ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha os valores.
# Variáveis de ambiente do sistema têm precedência sobre valores definidos aqui.

# ------------------------------------------------------------------------------
# Servidor
# ------------------------------------------------------------------------------

# Porta do servidor HTTP (1024-65535, padrão: 8080)
SERVER_PORT=8080

# Timeout para graceful shutdown em segundos (padrão: 30)
SHUTDOWN_TIMEOUT=30s

# ------------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# ------------------------------------------------------------------------------

# URL de conexão com o PostgreSQL (obrigatório)
DATABASE_URL=postgres://fintrack:fintrack@localhost:5432/fintrack?sslmode=disable

# ------------------------------------------------------------------------------
# JWT (JSON Web Tokens)
# ------------------------------------------------------------------------------

# Segredo para assinatura dos tokens JWT (obrigatório, mínimo 32 caracteres)
JWT_SECRET=change-me-to-a-secure-secret-with-at-least-32-chars

# Tempo de expiração do Access Token (padrão: 15m)
ACCESS_TOKEN_EXPIRY=15m

# Tempo de expiração do Refresh Token (padrão: 168h = 7 dias)
REFRESH_TOKEN_EXPIRY=168h

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

# Nível de log: debug, info, warn, error (padrão: info)
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Migrações
# ------------------------------------------------------------------------------

# Aplicar migrações automaticamente na inicialização (padrão: false)
AUTO_MIGRATE=false
